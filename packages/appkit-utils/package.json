{
  "name": "@reown/appkit-utils-react-native",
  "version": "1.1.1",
  "main": "lib/commonjs/exports/index.js",
  "types": "lib/typescript/exports/index.d.ts",
  "module": "lib/module/exports/index.js",
  "source": "src/exports/index.ts",
  "exports": {
    ".": {
      "types": "./dist/types/exports/index.d.ts",
      "import": "./dist/esm/exports/index.js",
      "default": "./dist/esm/exports/index.js"
    },
    "./ethers": {
      "types": "./dist/types/exports/ethers.d.ts",
      "import": "./dist/esm/exports/ethers.js",
      "default": "./dist/esm/exports/ethers.js"
    },
    "./solana": {
      "types": "./dist/types/exports/solana.d.ts",
      "import": "./dist/esm/exports/solana.js",
      "default": "./dist/esm/exports/solana.js"
    }
  },
  "scripts": {
    "build": "bob build",
    "clean": "rm -rf lib",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx"
  },
  "files": [
    "src",
    "lib",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__"
  ],
  "keywords": [
    "web3",
    "crypto",
    "ethereum",
    "appkit",
    "walletconnect",
    "react-native"
  ],
  "repository": "https://github.com/reown-com/appkit-react-native",
  "author": "Reown <support@reown.com> (https://reown.com)",
  "homepage": "https://reown.com/appkit",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/reown-com/appkit-react-native/issues"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "dependencies": {
    "@reown/appkit-common-react-native": "workspace:*",
    "@reown/appkit-core-react-native": "workspace:*",
    "@reown/appkit-wallet-react-native": "workspace:*",
    "@walletconnect/logger": "2.1.2",
    "@walletconnect/universal-provider": "2.17.2",
    "valtio": "1.10.5",
    "viem": "2.x"
  },
  "devDependencies": {
    "@coinbase/wallet-sdk": "4.2.4",
    "@solana/wallet-adapter-base": "0.9.23",
    "@solana/web3.js": "1.95.8"
  },
  "react-native": "src/exports/index.ts",
  "eslintIgnore": [
    "node_modules/",
    "lib/"
  ]
}

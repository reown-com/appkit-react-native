{
  "name": "expo-multichain",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "start:dev-client": "expo start --dev-client",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "build:android": "cd android && ./gradlew assembleRelease",
    "build:android:debug": "cd android && ./gradlew assembleDebug",
    "build:android:bundle": "cd android && ./gradlew bundleRelease",
    "build:ios": "cd ios && xcodebuild -workspace expomultichain.xcworkspace -scheme expomultichain -configuration Release -sdk iphonesimulator CODE_SIGNING_ALLOWED=NO",
    "build:ios:debug": "cd ios && xcodebuild -workspace expomultichain.xcworkspace -scheme expomultichain -configuration Debug -sdk iphonesimulator CODE_SIGNING_ALLOWED=NO",
    "clean:android": "cd android && ./gradlew clean",
    "clean:ios": "cd ios && xcodebuild clean -workspace expomultichain.xcworkspace -scheme expomultichain",
    "prebuild": "expo prebuild",
    "prebuild:clean": "rm -rf android ios && expo prebuild",
    "pods:install": "cd ios && bundle install && bundle exec pod install",
    "pods:update": "cd ios && bundle exec pod update",
    "web": "expo start --web",
    "lint": "expo lint",
    "maestro:test": ".maestro/run-tests.sh"
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "@expo/vector-icons": "^15.0.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/netinfo": "11.4.1",
    "@react-navigation/bottom-tabs": "^7.3.10",
    "@react-navigation/elements": "^2.3.8",
    "@react-navigation/native": "^7.1.6",
    "@reown/appkit-bitcoin-react-native": "2.0.1",
    "@reown/appkit-react-native": "2.0.1",
    "@reown/appkit-solana-react-native": "2.0.1",
    "@reown/appkit-wagmi-react-native": "2.0.1",
    "@tanstack/react-query": "^5.81.5",
    "@walletconnect/react-native-compat": "2.22.2",
    "expo": "54.0.12",
    "expo-application": "~7.0.7",
    "expo-blur": "~15.0.7",
    "expo-build-properties": "~1.0.9",
    "expo-clipboard": "~8.0.7",
    "expo-constants": "~18.0.9",
    "expo-dev-client": "~6.0.13",
    "expo-font": "~14.0.8",
    "expo-haptics": "~15.0.7",
    "expo-image": "~3.0.8",
    "expo-linking": "~8.0.8",
    "expo-router": "~6.0.10",
    "expo-splash-screen": "~31.0.10",
    "expo-status-bar": "~3.0.8",
    "expo-symbols": "~1.0.7",
    "expo-system-ui": "~6.0.7",
    "expo-web-browser": "~15.0.8",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.4",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-get-random-values": "~1.11.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.5.1",
    "text-encoding": "0.7.0",
    "viem": "2.37.11",
    "wagmi": "2.17.5"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@types/react": "~19.1.10",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~10.0.0",
    "typescript": "~5.9.2"
  },
  "overrides": {
    "react": "19.1.0",
    "hono": "4.11.10",
    "h3": "1.15.5",
    "tar": "7.5.8",
    "node-forge": "1.3.2",
    "undici": "6.23.0",
    "preact": "10.28.2",
    "js-yaml": "3.14.2",
    "valibot": "1.2.0",
    "lodash": "4.17.23",
    "bn.js": "5.2.3",
    "minimatch": "10.2.1"
  },
  "private": true
}
